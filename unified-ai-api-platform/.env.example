# ---------------------------------------------------------------------------
# Unified AI API Platform — configuration
# Copy to `.env` and adjust. Every value can also be set as an env variable.
# ---------------------------------------------------------------------------

# --- Stage 1: Foundation -----------------------------------------------------
APP_NAME="Unified AI API Platform"
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Provider credentials (leave empty to use built-in mock mode)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Override provider endpoints (proxies, Azure-style gateways, ...)
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
ANTHROPIC_VERSION=2023-06-01
PROVIDER_TIMEOUT_SECONDS=30

# auto  -> mock only providers without credentials (default)
# always-> force mock responses for every provider (great for dev/tests)
# never -> live calls only; providers without keys become "unconfigured"
MOCK_PROVIDERS=auto

# API-key auth for this platform's own clients (comma separated).
# Leave empty to disable auth (local development).
API_KEYS=
MASTER_API_KEY=

# --- Stage 2: Cost optimization ----------------------------------------------
PRICING_FILE=config/pricing.json
COST_TRACKING_ENABLED=true
USAGE_STORE_PATH=data/usage.jsonl
MONTHLY_BUDGET_USD=0               # 0 = no global budget
BUDGET_ALERT_THRESHOLDS=0.5,0.8,1.0

# --- Stage 3: Intelligent routing --------------------------------------------
DEFAULT_STRATEGY=balanced          # cost | latency | balanced
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
MAX_FALLBACKS=2

# --- Stage 4: Speed & performance --------------------------------------------
REDIS_URL=                         # e.g. redis://localhost:6379/0 (empty = in-memory cache)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BURST=20
QUEUE_MAX_CONCURRENCY=8
METRICS_ENABLED=true
